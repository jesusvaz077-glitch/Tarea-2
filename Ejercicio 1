#include <stdio.h>

int main() 
{
    int num1, num2;
    printf("da dos numeros y calcular la suma, resta y multiplicacíon");
    printf("           da el primer numero");
    scanf("%d", &num1);
    printf("da el segundo numero");
    scanf("%d", &num2);
    printf("la suma es: %d\n", num1 + num2);
    printf("la resta es: %d\n", num1-num2);
    printf("la multiplicación es: %d\n", num1*num2);
}
